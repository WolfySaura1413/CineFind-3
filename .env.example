# Watchmode API — two keys provisioned (use KEY_1 for primary, KEY_2 as fallback)
WATCHMODE_API_KEY_1=your_primary_key_here
WATCHMODE_API_KEY_2=your_fallback_key_here

# Firebase (if chosen) — from Firebase Console > Project Settings > Service Accounts
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
FIREBASE_APP_ID=your_firebase_app_id_here

# Supabase (if using instead of Firebase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# App configuration
NODE_ENV=development
API_TIMEOUT_MS=10000
CACHE_EXPIRY_SEARCH_HOURS=1
CACHE_EXPIRY_SOURCES_HOURS=24
